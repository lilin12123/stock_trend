# Edit this file after you install the Linux OpenD package on EC2.
# Replace the command below with the actual binary path and flags from the
# OpenD package version you install.
#
# Example only:
# OPEND_COMMAND="/opt/FutuOpenD/FutuOpenD --host=127.0.0.1 --port=11111 --login_account=YOUR_ACCOUNT --login_pwd=YOUR_PASSWORD"

OPEND_COMMAND="/opt/FutuOpenD/FutuOpenD --host=127.0.0.1 --port=11111"
